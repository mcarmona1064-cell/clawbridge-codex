## ── REQUIRED ──────────────────────────────────────────────────────────────────
# Your Claude OAuth token (from: npx claude setup-token)
CLAUDE_CODE_OAUTH_TOKEN=

# Your Telegram bot token (from: @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# Agent display name
ASSISTANT_NAME=ClawBridge

## ── ADMIN ──────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

## ── HINDSIGHT (semantic memory — host process only, not passed to containers) ──
# Hindsight runs on the host and is managed automatically by clawbridge setup.
# You do not need to fill these in manually — they are auto-configured.
HINDSIGHT_URL=http://localhost:8888
HINDSIGHT_API_KEY=
HINDSIGHT_DB_PASSWORD=

## ── NANGO (OAuth integrations) ─────────────────────────────────────────────────
NANGO_DB_PASSWORD=
NANGO_SECRET_KEY=
NANGO_ENCRYPTION_KEY=
# These are auto-generated by clawbridge setup — you don't need to fill them in manually
NANGO_DB_HOST=nango-db
NANGO_DB_PORT=5432
NANGO_DB_USER=nango
NANGO_DB_NAME=nango
NANGO_REDIS_URL=redis://nango-redis:6379
NANGO_SERVER_PORT=3003
SERVER_URL=http://localhost:3003
CONNECT_URL=http://localhost:3009

## ── OPTIONAL ───────────────────────────────────────────────────────────────────
WEBHOOK_PORT=3001
LOG_LEVEL=info
