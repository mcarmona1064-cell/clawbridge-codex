NANGO_SECRET_KEY=your-secret-key-here
NANGO_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32
NANGO_DB_HOST=nango-db
NANGO_DB_PORT=5432
NANGO_DB_USER=nango
NANGO_DB_PASSWORD=change-this-password
NANGO_DB_NAME=nango
NANGO_REDIS_URL=redis://nango-redis:6379
NANGO_SERVER_PORT=3003
SERVER_URL=http://localhost:3003
CONNECT_URL=http://localhost:3009


# Anthropic (fallback if no per-client key stored)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Portal API URL + admin token (for MCP server to fetch per-client keys)
PORTAL_API_URL=http://localhost:3010
PORTAL_ADMIN_TOKEN=your-portal-jwt-token

# ── Hindsight memory (optional — semantic per-client memory) ──────────────────
# Generate a random password: openssl rand -hex 16
HINDSIGHT_DB_PASSWORD=
# Generate a random API key: openssl rand -hex 32
HINDSIGHT_API_KEY=
# Points to the Hindsight API container (default when running via docker-compose)
HINDSIGHT_URL=http://localhost:8888
# Your Claude OAuth token — run: claude setup-token (or onecli token show)
CLAUDE_CODE_OAUTH_TOKEN=

# Server
WEBHOOK_PORT=3000

# Agent identity
ASSISTANT_NAME=Andy
ASSISTANT_HAS_OWN_NUMBER=false

# Logging
LOG_LEVEL=info

# Error handling & alerts
TELEGRAM_ALERT_CHAT_ID=
ERROR_AUTO_FIX=false
