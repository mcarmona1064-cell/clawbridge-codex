# ClawBridge Agent — environment variables
# Copy to .env and fill in your values.
# Run `pnpm run setup:wizard` to generate this file interactively.

# ── Agent identity ────────────────────────────────────────────────────────────
AGENT_NAME=ClawBridge

# ── Claude authentication ─────────────────────────────────────────────────────
# Option 1: Long-lived OAuth token (recommended — from `claude setup-token`)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat...

# Option 2: API key (from console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-api...

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather — format: 123456789:ABCdef...
TELEGRAM_BOT_TOKEN=

# ── Error handling & alerts ───────────────────────────────────────────────────
TELEGRAM_ALERT_CHAT_ID=your-personal-telegram-chat-id
ERROR_AUTO_FIX=false

# ── Discord (optional) ────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=

# ── Slack (optional) ──────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── WhatsApp Cloud API (optional) ─────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ── Portal admin credentials ──────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# ── Portal API (JWT) ──────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-this-secret

# ── Encryption key for Anthropic API keys stored in portal DB (AES-256-GCM) ──
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Nango (integrations — optional) ──────────────────────────────────────────
# Generate with: openssl rand -hex 32
NANGO_SECRET_KEY=
NANGO_ENCRYPTION_KEY=
NANGO_DB_HOST=nango-db
NANGO_DB_PORT=5432
NANGO_DB_USER=nango
NANGO_DB_PASSWORD=change-this-password
NANGO_DB_NAME=nango
NANGO_REDIS_URL=redis://nango-redis:6379
NANGO_SERVER_PORT=3003
SERVER_URL=http://localhost:3003
CONNECT_URL=http://localhost:3009
NANGO_SERVER_URL=http://localhost:3003
PORTAL_ADMIN_TOKEN=

# ── Retell voice integration (optional) ───────────────────────────────────────
RETELL_API_KEY=
RETELL_WEBHOOK_SECRET=
RETELL_WEBHOOK_PORT=3020

# Set to enable semantic memory search (upgrades from keyword to vector similarity)