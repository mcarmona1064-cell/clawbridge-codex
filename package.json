{
  "name": "clawbridge-agent",
  "version": "2.4.5",
  "description": "AI agent platform for ClawBridge Agency. Self-hosted, secure, customizable.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "dist/index.js",
  "author": "ClawBridge",
  "repository": {
    "type": "git",
    "url": "https://github.com/other2368-byte/clawbridge-agent.git"
  },
  "homepage": "https://github.com/other2368-byte/clawbridge-agent",
  "files": [
    "dist",
    "container",
    "scripts",
    "integrations/docker-compose.yml",
    "integrations/auth-portal",
    "integrations/start.sh",
    "launchd",
    "setup",
    "README.md",
    "LICENSE",
    "portal/README.md",
    "portal/docker-compose.yml",
    "portal/api/src",
    "portal/api/package.json",
    "portal/api/tsconfig.json",
    "portal/app/src",
    "portal/app/package.json",
    "portal/app/next.config.js",
    "portal/app/postcss.config.js",
    "portal/app/tailwind.config.js",
    "portal/app/tsconfig.json",
    "integrations/mcp-server/src",
    "integrations/mcp-server/package.json",
    "integrations/mcp-server/tsconfig.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai-agent",
    "claude",
    "anthropic",
    "chatbot",
    "telegram",
    "whatsapp",
    "discord",
    "slack",
    "self-hosted",
    "white-label"
  ],
  "bin": {
    "clawbridge-agent": "./dist/setup/index.js",
    "clawbridge": "./dist/setup/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "prepublishOnly": "pnpm build",
    "setup": "tsx setup/index.ts",
    "setup:wizard": "tsx src/setup/index.ts",
    "setup:auto": "tsx setup/auto.ts",
    "migrate": "tsx src/setup/migrate.ts",
    "chat": "tsx scripts/chat.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node -e \"console.log('\\n\u2705 ClawBridge Agent installed. Run: clawbridge-agent setup\\n')\""
  },
  "dependencies": {
    "@clack/core": "^1.2.0",
    "@clack/prompts": "^1.2.0",
    "@vectorize-io/hindsight-client": "^0.5.4",
    "better-sqlite3": "11.10.0",
    "chat": "^4.24.0",
    "cron-parser": "5.5.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
