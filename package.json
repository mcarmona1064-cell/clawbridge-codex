{
  "name": "clawbridge-codex",
  "version": "2.9.4",
  "description": "AI agent platform for ClawBridge Agency, powered by OpenAI Codex. Self-hosted, secure, customizable.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "dist/index.js",
  "author": "ClawBridge",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcarmona1064-cell/clawbridge-codex.git"
  },
  "homepage": "https://github.com/mcarmona1064-cell/clawbridge-codex",
  "files": [
    "dist",
    "container",
    "scripts",
    "integrations/docker-compose.yml",
    "integrations/auth-portal",
    "integrations/start.sh",
    "launchd",
    "systemd",
    "setup",
    "README.md",
    "LICENSE",
    "integrations/mcp-server/src",
    "integrations/mcp-server/package.json",
    "integrations/mcp-server/tsconfig.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai-agent",
    "codex",
    "openai",
    "chatbot",
    "telegram",
    "whatsapp",
    "discord",
    "slack",
    "self-hosted",
    "white-label"
  ],
  "bin": {
    "clawbridge-codex": "./dist/setup/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "node -e \"try{require('child_process').execSync('husky',{stdio:'inherit'})}catch(e){}\"",
    "prepublishOnly": "pnpm build",
    "setup": "tsx setup/index.ts",
    "setup:wizard": "tsx src/setup/index.ts",
    "setup:auto": "tsx setup/auto.ts",
    "migrate": "tsx src/setup/migrate.ts",
    "chat": "tsx scripts/chat.ts",
    "auth": "tsx setup/whatsapp-auth.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node -e \"try{require('better-sqlite3')}catch(e){console.error('\\n⚠ ClawBridge needs build tools for the database driver.\\nRun: apt install -y python3 make g++ (Ubuntu/Debian) or yum install -y python3 make gcc-c++ (CentOS)\\nThen: npm install -g clawbridge-codex\\n')}\""
  },
  "dependencies": {
    "@clack/core": "^1.2.0",
    "@clack/prompts": "^1.2.0",
    "@vectorize-io/hindsight-client": "^0.5.4",
    "better-sqlite3": "11.10.0",
    "chat": "^4.24.0",
    "cron-parser": "5.5.0",
    "discord.js": "^14.26.4",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  }
}
